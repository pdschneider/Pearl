#!/bin/sh
# Runs after files have been removed
# This script cleans up remaining configuration files

set -e

# Clean up desktop and icon cache after removal
update-desktop-database /usr/share/applications 2>/dev/null || true
gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true

# Remove any leftover menu items (Cinnamon/Mint sometimes needs this)
rm -f /usr/share/applications/pearl.desktop 2>/dev/null || true

exit 0